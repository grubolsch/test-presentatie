{
    "name": "presentatie/phpunit-oefeningen",
    "description": "PHPUnit oefeningen",
    "type": "project",
    "require": {
        "php": "^8.2",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-oefening1": "vendor/bin/phpunit tests/Unit/Oefening1",
        "test-oefening2": "vendor/bin/phpunit tests/Unit/Oefening2",
        "test-oefening3": "vendor/bin/phpunit tests/Unit/Oefening3",
        "test-oefening4": "vendor/bin/phpunit tests/Unit/Oefening4",
        "test-oefening5": "vendor/bin/phpunit tests/Unit/Oefening5",
        "test-oefening6": "vendor/bin/phpunit tests/Unit/Oefening6",
        "test-oefening7": "vendor/bin/phpunit tests/Unit/Oefening7",
        "test-demo": "vendor/bin/phpunit tests/Unit/Demo"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
